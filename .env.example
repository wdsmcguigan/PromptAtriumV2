# PromptAtrium environment variables
# Copy to .env and fill in. The API server reads these at startup.

# === REQUIRED ===

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/promptatrium

# Session secret (minimum 32 characters; generate with: openssl rand -hex 32)
SESSION_SECRET=

# OIDC login (Google by default — see AUTH_SETUP.md for client setup)
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Public URL of the app. Required in production.
# The OAuth callback is APP_URL/api/callback (register it on the OAuth client).
# Defaults to http://localhost:8080 in development.
#APP_URL=https://your-domain.com

# === SERVER ===

# API server port (default 8080)
#PORT=8080

# Directory of the built frontend to serve in production
# (defaults to dist/public next to the server bundle)
#STATIC_DIR=

# === OBJECT STORAGE (Google Cloud Storage) ===

# Either an inline service-account JSON key...
#GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
# ...or Application Default Credentials:
#GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# Bucket paths (kept from the Replit-era /bucket-name/... format)
#PUBLIC_OBJECT_SEARCH_PATHS=/bucket-name/public
#PRIVATE_OBJECT_DIR=/bucket-name/.private

# === AI SERVICES (optional; features degrade gracefully) ===

#OPENAI_API_KEY=sk-...
#GEMINI_API_KEY=

# === GOOGLE INTEGRATIONS (optional) ===

# OAuth client for the Google Drive export feature
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
#GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# Google Sheets (AI services directory); API key for public sheets,
# otherwise the service account above is used
#GOOGLE_SHEETS_API_KEY=

# === PAYMENTS (optional; marketplace is feature-flagged off) ===

#STRIPE_SECRET_KEY=
#STRIPE_WEBHOOK_SECRET=
#VITE_STRIPE_PUBLIC_KEY=
#PAYPAL_CLIENT_ID=
#PAYPAL_CLIENT_SECRET=

# === ADVANCED ===

# Override the OIDC issuer (defaults to https://accounts.google.com)
#OIDC_ISSUER_URL=https://accounts.google.com

# Frontend dev server (Vite): port and API proxy target
#PORT=5173
#API_PROXY_TARGET=http://localhost:8080
