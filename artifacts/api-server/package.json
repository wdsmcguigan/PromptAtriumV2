{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "backfill:v2": "pnpm run build && node --enable-source-maps ./dist/scripts/backfill-v2.mjs",
    "import:seed": "pnpm run build && node --enable-source-maps ./dist/scripts/import-seed.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.15.2",
    "@google/genai": "^0.14.1",
    "@google/generative-ai": "^0.24.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "axios": "^1.9.0",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "google-auth-library": "^9.15.1",
    "googleapis": "^149.0.0",
    "multer": "^1.4.5-lts.2",
    "nanoid": "^5.1.5",
    "openai": "^5.3.0",
    "openid-client": "^6.8.4",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "ws": "^8.18.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/multer": "^1.4.12",
    "@types/node": "catalog:",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0"
  }
}
